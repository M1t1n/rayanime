# ─── Neon Free Postgres ───
# 1. Sign up at https://neon.tech (free)
# 2. Create a project → copy connection strings
# 3. Use the POOLED url for DATABASE_URL and the DIRECT url for DIRECT_URL
#
# Pooled connection (for app queries via serverless):
DATABASE_URL="postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/rayanime?sslmode=require&pgbouncer=true"
# Direct connection (for Prisma migrations / db push):
DIRECT_URL="postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/rayanime?sslmode=require"

# ─── NextAuth ───
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"
# On Vercel, set NEXTAUTH_URL to your production URL (e.g. https://rayanime.vercel.app)
